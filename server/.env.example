# Node
NODE_ENV=development
PORT=3000
# Optional: browser origin for CORS (e.g. http://localhost:5173)
CORS_ORIGIN=

# ——— Alibaba (ECS / RDS / OSS / MNS) ———
# MySQL on Alibaba RDS
DATABASE_URL=mysql://user:pass@rds-endpoint:3306/yourdb

# OSS presigned upload/download (V1 signature; add V4 in production if you need strict headers)
ALIBABA_OSS_REGION=oss-ap-southeast-1
# Optional custom endpoint (e.g. internal, accelerate)
# ALIBABA_OSS_ENDPOINT=
ALIBABA_OSS_BUCKET=your-bucket
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=

# MNS: optional HTTP forwarder to your queue; replace with MNS API later
ALIBABA_MNS_QUEUE_URL=
ALIBABA_MNS_ACCESS_KEY_ID=
ALIBABA_MNS_ACCESS_KEY_SECRET=

# OCR / document parsing: your gateway or OpenAPI entry (JSON in/out)
# ALIBABA_OCR_ENDPOINT=https://ocr-gateway.example/recognize

# ——— AWS (Lambda / AI / events / logs) ———
# Prefer IAM task/instance role; otherwise static keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1

# Optional: DynamoDB single-table (partition key: id) for analytics / audit logs
# AWS_DYNAMODB_LOGS_TABLE=tngreach-logs

# Optional: default Lambda to invoke
# AWS_LAMBDA_NAME=tngreach-worker

# Optional: SNS when not passing topic in job metadata
# AWS_SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456:topic

# Optional: S3 media for Transcribe (s3://bucket/key) — use same region as job or configure accordingly
# AWS_S3_MEDIA_BUCKET=
